# AUTOSET VARIABLES (CONTROLLED BY scripts/run.sh)
## DO NOT MODIFY THIS SECTION
# >>>----------------------------------------------------

ROS2_WORKSPACE=""
ROS2_RUN_COMMAND=""
ROS2_IP=""

# <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<



# STATIC VARIABLES
## DO NOT MODIFY THIS SECTION UNLESS YOU KNOW WHAT YOU ARE DOING
# >>>----------------------------------------------------

ROS2_ENV_IMAGE=reg.iacsl.org/a4-vai/sils-container:jazzy-cuda12.6-tensorrt10.4-cudnn9.3
ROS2_ENV_CONTAINER=ros2-env

# <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<



# MANUALSET VARIABLES
## YOU CAN MODIFY THIS SECTION
# >>>----------------------------------------------------

# ROS2 APP TO AUTO-RUN ON `gazebo-classic-sitl run`.
# RUNS scripts/ros2/apps/<ROS2_APP>.sh (the uXRCE-DDS agent always runs alongside it).
# TO ADD A NEW APP: drop a new scripts/ros2/apps/<name>.sh and set ROS2_APP="<name>".
# LEAVE EMPTY (ROS2_APP="") TO ONLY RUN THE AGENT AND IDLE.
ROS2_APP="velocity_offboard_test"
# ROS2_APP="position_offboard_test"

# STATE_YOUR_VARIABLES_HERE=""

